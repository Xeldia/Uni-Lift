{
  "name": "unilift-backend",
  "version": "1.0.0",
  "description": "UniLift campus rideshare backend API",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "check:build": "npm run build",
    "reset:users": "tsx src/scripts/reset-users.ts",
    "create:admin": "tsx src/scripts/create-admin.ts",
    "smoke:health": "node -e \"fetch(process.env.BACKEND_URL || 'http://localhost:3001/health').then(r=>r.json()).then(d=>{console.log(d); if(!d?.success) process.exit(1);}).catch(()=>process.exit(1))\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
